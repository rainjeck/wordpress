/*!
 --- UI -----------------------------------------
*/

body
  font-family: $font;
  color: $colorText;


.container
  width: 100%;
  max-width: $containerWidth;
  padding-left: $containerPadding;
  padding-right: $containerPadding;
  margin: 0 auto


.link
  transit();

  &:hover
    opacity: 0.6;


.is-process
  position: relative;

  &:before
    pseudo();
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background-color: rgba(#fff,0.5);
    z-index: 10;

  &:after
    pseudo();
    width: 40px;
    height: 40px;
    border-radius: 100%;
    top: 50%;
    left: 50%;
    margin-top: -20px;
    margin-left: -20px;
    border-width: 5px;
    border-color: $colorAccentDark rgba(#fff,0);
    border-style: solid;
    animation: process-rotate 1s linear infinite forwards;
    z-index: 15;

@keyframes process-rotate
  from
    transform: rotate(0deg);
  to
    transform: rotate(360deg);


@import 'framework';


/*!
  --- ELEMENTS ------------------------
*/
.ui-icon
  size(16px,16px);
  flex: none;

  .ico
    size(100%,100%);

.ui-picture-bg
  position: absolute;
  size(100%,100%);
  top: 0;
  left: 0;

  img
    size(100%,100%);
    object-fit: cover;


.ui-picture-cover
  img
    size(100%,100%);
    object-fit: cover;


/*!
  --- FORM ----------------------------
*/
.ui-fg
  position: relative

  margin-bottom: 1em

  &.is-mb-0
    margin-bottom: 0

  .error-message
    position: absolute
    bottom: 3px
    right: 5px
    font-size: 0.8em
    color: $colorError
